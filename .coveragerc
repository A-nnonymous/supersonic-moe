[run]
branch = True
parallel = True
concurrency = multiprocessing
source = sonicmoe
omit =
    sonicmoe/_*compat*.py
    sonicmoe/cli/*
    sonicmoe/quack_utils/_legacy*
    */tests/*

[report]
exclude_lines =
    pragma: no cover
    raise NotImplementedError
    if TYPE_CHECKING:
    if __name__ == .__main__.:
skip_empty = True
